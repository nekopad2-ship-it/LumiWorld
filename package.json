{
  "name": "lwe-living-world-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun.cmd build src/backend.ts --outfile dist/backend.js --target bun && bun.cmd build src/frontend.ts --outfile dist/frontend.js --target browser",
    "typecheck": "bun.cmd x tsc --noEmit",
    "lint": "bun.cmd x eslint .",
    "format:check": "bun.cmd x prettier --check .",
    "test": "bun.cmd test tests/unit",
    "test:integration": "bun.cmd test tests/integration",
    "package:extension": "bun.cmd run scripts/package-extension.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "lumiverse-spindle-types": "^0.5.25",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
